rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /// Ensures only the listed fields are present in the incoming data.
    function hasOnlyFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    /// Validates that the userId field in the document matches the auth UID.
    function ownershipInvariant(userId) {
      return request.resource.data.userId == userId;
    }

    function validUserDocument(userId) {
      return hasOnlyFields(['id', 'email', 'displayName', 'profile', 'createdAt', 'updatedAt'])
        && request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 100
        && request.resource.data.profile is map
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validWorkoutPlan(userId) {
      return ownershipInvariant(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.workoutsPerWeek is int
        && request.resource.data.workoutsPerWeek >= 1
        && request.resource.data.workoutsPerWeek <= 7;
    }

    function validWorkoutSession(userId) {
      return ownershipInvariant(userId)
        && request.resource.data.status in ['inProgress', 'completed', 'abandoned']
        && request.resource.data.workoutName is string;
    }

    function validProgressRecord(userId) {
      return ownershipInvariant(userId)
        && request.resource.data.exerciseId is string;
    }

    function validPersonalRecord(userId) {
      return ownershipInvariant(userId)
        && request.resource.data.exerciseId is string
        && request.resource.data.type in ['weight', 'reps', 'volume', 'estimated1RM']
        && request.resource.data.value is number
        && request.resource.data.value > 0;
    }

    function validBodyMeasurement(userId) {
      return ownershipInvariant(userId)
        && request.resource.data.date is timestamp;
    }

    // ── User document ──

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && validUserDocument(userId);

      allow update: if isOwner(userId)
        && validUserDocument(userId)
        // Cannot change id or email via client
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email;

      allow delete: if isOwner(userId);

      // ── Workout Plans ──

      match /workoutPlans/{planId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && validWorkoutPlan(userId);

        allow update: if isOwner(userId)
          && validWorkoutPlan(userId)
          // Cannot reassign plan to a different user
          && request.resource.data.userId == resource.data.userId;

        allow delete: if isOwner(userId);
      }

      // ── Workout Sessions ──

      match /workoutSessions/{sessionId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && validWorkoutSession(userId);

        allow update: if isOwner(userId)
          && validWorkoutSession(userId)
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.status in ['inProgress', 'completed', 'abandoned'];

        allow delete: if isOwner(userId);
      }

      // ── Progress Records ──

      match /progressRecords/{recordId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && validProgressRecord(userId);

        allow update: if isOwner(userId)
          && validProgressRecord(userId)
          && request.resource.data.userId == resource.data.userId;

        allow delete: if isOwner(userId);
      }

      // ── Personal Records ──

      match /personalRecords/{prId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && validPersonalRecord(userId);

        allow update: if isOwner(userId)
          && validPersonalRecord(userId)
          && request.resource.data.userId == resource.data.userId;

        allow delete: if isOwner(userId);
      }

      // ── Body Measurements ──

      match /bodyMeasurements/{measurementId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && validBodyMeasurement(userId);

        allow update: if isOwner(userId)
          && validBodyMeasurement(userId)
          && request.resource.data.userId == resource.data.userId;

        allow delete: if isOwner(userId);
      }
    }

    // ── Global read-only collections ──

    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /workoutTemplates/{templateId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── AI usage logs: write-only from Cloud Functions, deny client access ──

    match /aiUsageLogs/{logId} {
      allow read, write: if false;
    }

    // ── Deny everything else ──

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
